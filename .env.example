# Copy to `.env` in the same folder as main.py. Do not commit real keys.
# Google AI Studio → Create API key. Real keys are typically ~39 characters.
# main.py loads this file automatically (python-dotenv, override=True so .env wins over empty User env vars).
#
# Comma-separated browser origins allowed to call this API (CORS). Add your Vercel URL after deploy, e.g.:
# CORS_ALLOW_ORIGINS=https://clearrisk.vercel.app,https://clearrisk-xxx.vercel.app
CORS_ALLOW_ORIGINS=
GEMINI_API_KEY=
# Default in code is gemini-2.5-flash; override if your project uses another ID
GEMINI_MODEL=gemini-2.5-flash
